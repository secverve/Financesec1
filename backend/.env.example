REDIS_URL=redis://localhost:6379/0
MARKET_DATA_PROVIDER=mock
DEFAULT_ADMIN_EMAIL=CHANGE_ME_ADMIN_EMAIL
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DEFAULT_USER_EMAIL=CHANGE_ME_USER_EMAIL
DEFAULT_USER_PASSWORD=CHANGE_ME_USER_PASSWORD
ADDITIONAL_AUTH_CODE=000000
CORS_ORIGINS=http://localhost:3000
